rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default: lock everything until you model collections and tighten per-doc rules.
    match /{document=**} {
      allow read, write: if false;
    }

    // Example pattern for public read / admin write (uncomment and adapt when ready):
    // match /posts/{postId} {
    //   allow read: if true;
    //   allow write: if request.auth != null && request.auth.token.admin == true;
    // }
  }
}
