# Copy to .env.local for local dev. Prefix VITE_ is exposed to the browser — never put secrets here.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Stripe publishable key only (pk_...). Secret keys live in Cloud Functions / Vercel serverless later.
# VITE_STRIPE_PUBLISHABLE_KEY=
